{
  "name": "ai-trading",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.14.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@azure/identity": "^3.4.0",
    "@azure/keyvault-secrets": "^4.7.0",
    "@supabase/supabase-js": "2.108.2",
    "technicalindicators": "^3.1.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @ai-trading/web dev",
    "dev:backend": "supabase start && supabase functions serve --env-file .env",
    "dev:all": "docker-compose down && supabase start && (supabase functions serve --env-file .env & pnpm --filter @ai-trading/web dev)",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  }
}